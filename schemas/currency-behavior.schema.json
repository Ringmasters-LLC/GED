{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "primaryCurrency", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "primaryCurrency": { "type": "string", "pattern": "^[A-Z]{3}$" },
      "commonCurrencies": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z]{3}$" } },
      "cashCurrencyDiffersFromSettlement": { "type": "boolean" },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
