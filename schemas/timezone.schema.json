{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "primaryZone", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "primaryZone": { "type": "string" },
      "zones": { "type": "array", "items": { "type": "string" } },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
