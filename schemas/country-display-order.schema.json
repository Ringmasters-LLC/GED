{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "priority": { "type": "integer" },
      "popular": { "type": "boolean" },
      "region": { "type": "string" },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
