{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "nameOrder", "supportsSingleName", "requiresFamilyName", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "nameOrder": { "enum": ["given_family", "family_given"] },
      "supportsSingleName": { "type": "boolean" },
      "requiresFamilyName": { "type": "boolean" },
      "patronymicCommon": { "type": "boolean" },
      "middleNameCommon": { "type": "boolean" },
      "honorificCommon": { "type": "boolean" },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
