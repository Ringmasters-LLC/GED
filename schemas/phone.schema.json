{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "callingCodes", "recommendedLibrary", "normalizationTarget", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "callingCodes": {
        "type": "array",
        "items": { "type": "string" }
      },
      "recommendedLibrary": { "type": "string" },
      "normalizationTarget": { "type": "string" },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
