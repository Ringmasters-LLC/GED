{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "iso2",
      "iso3",
      "numeric",
      "name",
      "territoryType",
      "commerceSelectable",
      "confidence",
      "sources",
      "updatedAt"
    ],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "iso3": { "type": "string", "pattern": "^[A-Z]{3}$" },
      "numeric": { "type": "string", "pattern": "^\\d{3}$" },
      "name": { "type": "string" },
      "territoryType": { "enum": ["sovereign", "dependent", "disputed", "administrative"] },
      "parentTerritory": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "commerceSelectable": { "type": "boolean" },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "sources": { "type": "array", "items": { "type": "string" } },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
