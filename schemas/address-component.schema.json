{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "components", "order", "streetAddressCentral", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "components": { "type": "array", "items": { "type": "string" } },
      "order": { "enum": ["small_to_large", "large_to_small"] },
      "streetAddressCentral": { "type": "boolean" },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
