{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "used", "requiredForConsumerForms", "requiredForShipping", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "used": { "type": "boolean" },
      "requiredForConsumerForms": { "type": "boolean" },
      "requiredForShipping": { "type": "boolean" },
      "format": { "type": "string" },
      "regex": { "type": "string" },
      "examples": { "type": "array", "items": { "type": "string" } },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
