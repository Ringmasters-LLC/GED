{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["code", "names", "updatedAt"],
    "properties": {
      "code": { "type": "string", "pattern": "^[a-z]{2,3}$" },
      "names": { "type": "object", "additionalProperties": { "type": "string" } },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
