{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["iso2", "requiredFields", "fieldOrder", "updatedAt"],
    "properties": {
      "iso2": { "type": "string", "pattern": "^[A-Z]{2}$" },
      "requiredFields": { "type": "array", "items": { "type": "string" } },
      "fieldOrder": { "type": "array", "items": { "type": "string" } },
      "administrativeAreaLabel": { "type": "string" },
      "postalCodeLabel": { "type": "string" },
      "postalCodePosition": {
        "enum": ["before_city", "after_city", "after_admin_area", "top", "bottom"]
      },
      "addressLinesRecommended": { "type": "integer" },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
