{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["locale", "dateFormat", "updatedAt"],
    "properties": {
      "locale": { "type": "string" },
      "dateFormat": { "type": "string" },
      "timeCycle": { "enum": ["h11", "h12", "h23", "h24"] },
      "weekStart": { "enum": ["monday", "sunday", "saturday"] },
      "calendar": { "type": "string" },
      "alternateCalendars": { "type": "array", "items": { "type": "string" } },
      "updatedAt": { "type": "string", "format": "date" }
    }
  }
}
